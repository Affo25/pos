# Copy to Vercel → Project → Settings → Environment Variables (Production + Preview).
# CRA inlines REACT_APP_* at build time — redeploy after changes.
# Local dev: put this file in frontend/, save, then restart `npm start` (env is read at startup).

# Required: full API origin — NO /api suffix, NO trailing slash (code adds /api itself).
# NEVER use your *.vercel.app frontend URL — use your Railway backend hostname only.
# Do not leave this blank or whitespace-only or login will hit localhost:3000 and show "Cannot POST /api/...".
# Prefer https:// for Railway — http:// can redirect POST /login to GET and you get 404 on /api/users/login.
REACT_APP_API_URL=https://xxxx.up.railway.app

# Optional — only if features are used
REACT_APP_PIXABAY_API_KEY=
REACT_APP_FIREBASE_API_KEY=
REACT_APP_BASE_URL=
REACT_APP_API_ENDPOINT=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=
REACT_APP_GOOGLE_MAP_KEY=
REACT_APP_AUTH0_DOMAIN=
REACT_APP_AUTH0_CLIENT_ID=
