{
  "name": "datalitex",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "build": "npm run build -w inventory-backend",
    "start": "node backend/server.js",
    "start:all": "concurrently \"npm run server\" \"npm run client\"",
    "start:backend": "npm --workspace backend start",
    "client": "npm --prefix frontend start",
    "server": "npm --prefix backend start",
    "dev": "concurrently \"npm run server-dev\" \"npm run client\"",
    "server-dev": "npm --prefix backend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  },
  "dependencies": {
    "multer": "^2.0.2"
  }
}
